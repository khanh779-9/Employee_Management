# Option A: set full JDBC URL
DB_URL=jdbc:mysql://<host>:3306/ltudcsdl_doan

# Option B: if DB_URL is empty, app builds URL from DB_HOST/DB_PORT/DB_NAME
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ltudcsdl_doan

DB_USER=<username>
DB_PASSWORD=<password>
DB_DRIVER=com.mysql.cj.jdbc.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect
